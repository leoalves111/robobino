# Credenciais Binomo (DevTools > Network > wss://ws.binomo.com/)
AUTH_TOKEN=seu_auth_token_aqui
DEVICE_ID=seu_device_id_aqui

# Opcional
DEMO_MODE=true
ASSET_NAME=Crypto IDX
TIMEFRAME_SECONDS=300
STRATEGIES_DIR=strategies
COMPILED_DIR=compiled_strategies

# Inteligência local (signal_brain)
MIN_CONFIDENCE=52
SIGNAL_COOLDOWN_CANDLES=2
MIN_ADX=14

# Cache M5 — frescor e sessão operacional
CACHE_MAX_AGE_HOURS=24
CACHE_MAX_GAP_MULTIPLIER=2
CACHE_MAX_LAST_CANDLE_AGE_MULTIPLIER=3
CACHE_SAME_TRADING_DAY=false
CACHE_TZ_OFFSET=-3

# PM2 / Linux (24/7 — orquestrador autónomo)
# bot_settings.txt: MODO=auto (padrão) ou MODO=fixo + ESTRATEGIA=N
HEADLESS=true
ORCHESTRATOR_SWITCH_COOLDOWN=3
CONNECT_MAX_RETRIES=10
CONNECT_RETRY_SECONDS=15
LOG_LEVEL=INFO
LOG_DIR=logs

# Supabase — fonte da verdade (AWS + PC)
SUPABASE_ENABLED=false
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua_service_role_ou_anon_key
# Identifique cada robô (evita conflito de ordem)
BOT_INSTANCE_ID=aws-vps
BOT_INSTANCE_LABEL=AWS
BOT_ROLE=primary
# secondary = só monitora, não emite sinal se primary ativo
BOT_PEER_TTL_SEC=120
SUPABASE_SYNC_INTERVAL_SEC=30
SIGNAL_LOCK_SECONDS=300
ASSET_RIC=Z-CRY/IDX
